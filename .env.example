# OpenAI-compatible LLM API key. Leave unset to run in offline/demo mode
# with the deterministic local parser.
OPENAI_API_KEY=

# Optional: override the API base URL to point at another OpenAI-compatible
# provider (e.g. a local vLLM/Ollama server, Azure OpenAI, etc).
OPENAI_BASE_URL=

# Model name to use for parsing.
OPENAI_MODEL=gpt-4o-mini

# Path to the SQLite database file.
DATABASE_PATH=lifeops.db

# Default timezone used when the client doesn't specify one.
DEFAULT_TIMEZONE=America/Chicago

# Path to Google OAuth client credentials JSON (Desktop app type) for the
# Google Calendar MCP server. Leave unset to skip real calendar integration
# and keep using the local mock calendar tool.
GOOGLE_OAUTH_CREDENTIALS_PATH=

# Langfuse tracing (optional). Leave unset to skip - the agent runs exactly
# the same either way, you just won't get a trace tree of each turn.
# Get these from https://cloud.langfuse.com (or your self-hosted instance).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
