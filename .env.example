# OpenAI-compatible LLM API key. Leave unset to run in offline/demo mode
# with the deterministic local parser.
OPENAI_API_KEY=

# Optional: override the API base URL to point at another OpenAI-compatible
# provider (e.g. a local vLLM/Ollama server, Azure OpenAI, etc).
OPENAI_BASE_URL=

# Model name to use for parsing.
OPENAI_MODEL=gpt-4o-mini

# --- LLM gateway / model routing (app/llm_gateway.py) ---
# The cheap tier is a local quantized model served by Ollama; the cloud tier
# is the strong model. When routing is ON, simple/synthesis calls go local and
# real tool-calling goes cloud, with automatic local->cloud fallback.
# MODEL_ROUTING_ENABLED is a feature flag - leave false to send everything to
# the cloud model (safe default / instant rollback). To try local routing:
# install Ollama, run `ollama pull llama3.1:8b`, and set this true.
MODEL_ROUTING_ENABLED=false
CLOUD_MODEL=gpt-4o-mini
LOCAL_MODEL=ollama/llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_TIMEOUT_SECONDS=20

# Response cache + per-session guardrails (app/budget.py).
LLM_CACHE_ENABLED=true
SESSION_COST_CAP_USD=1.00
SESSION_RATE_LIMIT_PER_MIN=60

# Path to the SQLite database file.
DATABASE_PATH=lifeops.db

# Default timezone used when the client doesn't specify one.
DEFAULT_TIMEZONE=America/Chicago

# Path to Google OAuth client credentials JSON (Desktop app type) for the
# Google Calendar MCP server. Leave unset to skip real calendar integration
# and keep using the local mock calendar tool.
GOOGLE_OAUTH_CREDENTIALS_PATH=

# Optional: where the Calendar MCP server caches its OAuth token. Defaults
# to its own config dir (e.g. ~/.config/google-calendar-mcp), which is
# fine locally but does NOT persist on ephemeral hosts like Railway -
# see the "Google Calendar on Railway" section in README.md.
GOOGLE_CALENDAR_MCP_TOKEN_PATH=

# Shared username/password gate for the Gradio UI. Both must be set or the
# app runs with NO login (a warning is logged at startup either way) -
# strongly recommended for any publicly reachable deployment.
GRADIO_AUTH_USER=
GRADIO_AUTH_PASS=

# Langfuse tracing (optional). Leave unset to skip - the agent runs exactly
# the same either way, you just won't get a trace tree of each turn.
# Get these from https://cloud.langfuse.com (or your self-hosted instance).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
