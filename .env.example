# OpenAI-compatible LLM API key. Leave unset to run in offline/demo mode
# with the deterministic local parser.
OPENAI_API_KEY=

# Optional: override the API base URL to point at another OpenAI-compatible
# provider (e.g. a local vLLM/Ollama server, Azure OpenAI, etc).
OPENAI_BASE_URL=

# Model name to use for parsing.
OPENAI_MODEL=gpt-4o-mini

# --- LLM gateway / model routing (app/llm_gateway.py) ---
# The cheap tier is a local quantized model served by Ollama; the cloud tier
# is the strong model. When routing is ON, simple/synthesis calls go local and
# real tool-calling goes cloud, with automatic local->cloud fallback.
# MODEL_ROUTING_ENABLED is a feature flag - leave false to send everything to
# the cloud model (safe default / instant rollback). To try local routing:
# install Ollama, run `ollama pull llama3.1:8b`, and set this true.
MODEL_ROUTING_ENABLED=false
CLOUD_MODEL=gpt-4o-mini
LOCAL_MODEL=ollama/llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_TIMEOUT_SECONDS=20

# Response cache + per-session guardrails (app/budget.py).
LLM_CACHE_ENABLED=true
SESSION_COST_CAP_USD=1.00
SESSION_RATE_LIMIT_PER_MIN=60

# --- RAG over journal entries (app/journal_index.py) ---
# Retrieval uses Pinecone (managed serverless vector DB). Leave PINECONE_API_KEY
# unset to disable RAG entirely - the search_journal tool then reports
# "unavailable" and journal entries just aren't indexed (everything else works).
# Get a free key at https://app.pinecone.io.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=lifeops-journal
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
EMBEDDING_MODEL=text-embedding-3-small

# Path to the SQLite database file.
DATABASE_PATH=lifeops.db

# Default timezone used when the client doesn't specify one.
DEFAULT_TIMEZONE=America/Chicago

# Path to Google OAuth client credentials JSON (Desktop app type) for the
# Google Calendar MCP server. Leave unset to skip real calendar integration
# and keep using the local mock calendar tool.
GOOGLE_OAUTH_CREDENTIALS_PATH=

# Optional: where the Calendar MCP server caches its OAuth token. Defaults
# to its own config dir (e.g. ~/.config/google-calendar-mcp), which is
# fine locally but does NOT persist on ephemeral hosts like Railway -
# see the "Google Calendar on Railway" section in README.md.
GOOGLE_CALENDAR_MCP_TOKEN_PATH=

# Shared username/password gate for the Gradio UI (single-user mode only).
# Both must be set or the app runs with NO login. Superseded by "Sign in with
# Google" below when that is configured.
GRADIO_AUTH_USER=
GRADIO_AUTH_PASS=

# --- Multi-user "Sign in with Google" (app/web.py, app/auth.py) ---
# Set all four to switch the app into multi-user mode: each visitor signs in
# with their own Google account and acts on their OWN calendar/data. Leave
# GOOGLE_OAUTH_CLIENT_ID/SECRET unset to stay single-user (no login).
#
# Create a *Web application* OAuth client in Google Cloud Console (NOT the
# Desktop client the single-user MCP calendar uses) and register OAUTH_REDIRECT_URI
# on it verbatim.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Where Google returns users after consent. Must match a redirect URI on the
# OAuth client. Local: http://localhost:7860/oauth2callback . Production:
# https://<your-domain>/oauth2callback
OAUTH_REDIRECT_URI=http://localhost:7860/oauth2callback
# Signs the login session cookie. Any long random string; keep it stable in
# production. Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
# Encrypts stored Google refresh tokens at rest. If unset, a key is derived
# from SESSION_SECRET (still encrypted, but set this explicitly in production).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Langfuse tracing (optional). Leave unset to skip - the agent runs exactly
# the same either way, you just won't get a trace tree of each turn.
# Get these from https://cloud.langfuse.com (or your self-hosted instance).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
